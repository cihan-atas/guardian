# docker-compose.yml için gerekli ortam değişkenleri.
# Bu dosyayı ".env" olarak kopyalayıp değerleri kendi ortamınıza göre doldurun:
#   cp .env.example .env

POSTGRES_USER=guardian_user
POSTGRES_PASSWORD=degistirin-guclu-bir-parola
POSTGRES_DB=guardian_db

# Ajan↔sunucu kimlik doğrulaması artık öncelikli olarak mTLS (istemci
# sertifikası) ile yapılır. Bu token YALNIZCA eski kurulumlarla uyumluluk için
# opsiyonel bir yedektir; boş bırakılırsa yalnızca mTLS kabul edilir.
GUARDIAN_SECRET_TOKEN=degistirin-super-gizli-bir-token

# İlk yönetici hesabı (yalnızca ilk açılışta, admin_users tablosu boşken
# kullanılır). Giriş artık kullanıcı adı + parola iledir; statik admin token
# kaldırıldı. GUARDIAN_ADMIN_PASSWORD boş bırakılırsa sunucu rastgele bir
# geçici parola üretip log'a yazar (ilk girişte değiştirin).
GUARDIAN_ADMIN_USERNAME=admin
GUARDIAN_ADMIN_PASSWORD=degistirin-guclu-bir-parola

# ---------------------------------------------------------------------------
# Bildirimler & riskli komut alarmı (hepsi OPSİYONEL)
# Hiçbiri ayarlı değilse yalnızca uygulama içi (dashboard + canlı ekran) uyarı
# çalışır; dış bildirim gönderilmez.
# ---------------------------------------------------------------------------

# Webhook (Slack / Discord / Teams veya kendi servisiniz). Slack uyumlu
# {"text": ...} gövdesi gönderilir. Boş bırakılırsa webhook devre dışı.
GUARDIAN_WEBHOOK_URL=

# SMTP e-posta bildirimi. SMTP_HOST ve ALERT_EMAIL_TO birlikte doluysa aktifleşir.
GUARDIAN_SMTP_HOST=
GUARDIAN_SMTP_PORT=587
GUARDIAN_SMTP_USER=
GUARDIAN_SMTP_PASS=
GUARDIAN_SMTP_FROM=
# Uyarıların gönderileceği adres(ler); virgülle ayrılabilir.
GUARDIAN_ALERT_EMAIL_TO=

# Kritik riskli komut tespitinde otomatik aksiyon: none | terminate | ban
# (yalnızca "critical" ciddiyetli komutlarda uygulanır; varsayılan none = sadece uyar).
GUARDIAN_RISKY_AUTOACTION=none

# ---------------------------------------------------------------------------
# Agent oto-kurulumu (UI > Agent Kurulumu) — OPSİYONEL
# ---------------------------------------------------------------------------
# Agent sertifikaları sunucu tarafından imzalanır; bunun için CA özel anahtarı
# (ca.key) sunucuda erişilebilir olmalıdır. Docker'da certs dizini zaten
# bağlandığından /etc/guardian/certs/ca.key kullanılır. Anahtar yoksa oto-kurulum
# devre dışı kalır (sunucu normal çalışır). Yol: TLS_CA_KEY_FILE (server tarafı).
#
# Agent'ların sunucuya eriştiği genel taban URL (kurulum komutuna ve agent.conf'a
# gömülür). Örn: https://10.2.60.185:5555 . Boşsa istek Host'undan türetilir.
GUARDIAN_PUBLIC_URL=
# Web arayüzünün CORS için izin verilen origin'leri (virgülle ayrılmış).
# Örn: https://guardian.sirket.com,https://10.2.60.185 . Boş bırakılırsa tüm
# origin'lere izin verilir (joker) — üretimde mutlaka gerçek origin'e daraltın.
GUARDIAN_CORS_ORIGINS=
# Sunucunun script'e servis edeceği guardian-agent binary yolu (host'ta derleyip
# ./agent-dist/guardian-agent olarak koyun; docker-compose bunu /opt/guardian'a bağlar).
GUARDIAN_AGENT_BINARY_PATH=/opt/guardian/guardian-agent
# Windows hedefler için guardian-agent.exe yolu (GOOS=windows ile derleyip koyun).
# UI > Agent Kurulumu > Windows seçildiğinde PowerShell script'i bunu indirir.
GUARDIAN_AGENT_BINARY_PATH_WINDOWS=/opt/guardian/guardian-agent.exe
