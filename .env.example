# docker-compose.yml için gerekli ortam değişkenleri.
# Bu dosyayı ".env" olarak kopyalayıp değerleri kendi ortamınıza göre doldurun:
#   cp .env.example .env

POSTGRES_USER=guardian_user
POSTGRES_PASSWORD=degistirin-guclu-bir-parola
POSTGRES_DB=guardian_db

# Agent'ların sunucuya bağlanırken kullandığı paylaşımlı gizli anahtar.
GUARDIAN_SECRET_TOKEN=degistirin-super-gizli-bir-token

# Guardian CLI ve Web Arayüzü için yönetici token'ı.
GUARDIAN_ADMIN_TOKEN=degistirin-yonetici-icin-cok-gizli-bir-token
